[
  {
    "id": 1,
    "uuid": "genesis-1",
    "bibleverses": "起初，神创造天地。",
    "type": "genesis",
    "from": "创世记 1:1",
    "creator": "bible",
    "created_at": "0",
    "length": 10
  },
  {
    "id": 2,
    "uuid": "genesis-2",
    "bibleverses": "神说：“要有光”，就有了光。",
    "type": "genesis",
    "from": "创世记 1:3",
    "creator": "bible",
    "created_at": "0",
    "length": 16
  },
  {
    "id": 3,
    "uuid": "genesis-3",
    "bibleverses": "神说：“我们要照着我们的形像、按着我们的样式造人。”",
    "type": "genesis",
    "from": "创世记 1:26",
    "creator": "bible",
    "created_at": "0",
    "length": 30
  },
  {
    "id": 4,
    "uuid": "genesis-4",
    "bibleverses": "神就照着自己的形像造人，乃是照着他的形像造男造女。",
    "type": "genesis",
    "from": "创世记 1:27",
    "creator": "bible",
    "created_at": "0",
    "length": 28
  },
  {
    "id": 5,
    "uuid": "genesis-5",
    "bibleverses": "神看着一切所造的都甚好。",
    "type": "genesis",
    "from": "创世记 1:31",
    "creator": "bible",
    "created_at": "0",
    "length": 16
  },
  {
    "id": 6,
    "uuid": "genesis-6",
    "bibleverses": "耶和华神用地上的尘土造人，将生气吹在他鼻孔里，他就成了有灵的活人。",
    "type": "genesis",
    "from": "创世记 2:7",
    "creator": "bible",
    "created_at": "0",
    "length": 32
  },
  {
    "id": 7,
    "uuid": "genesis-7",
    "bibleverses": "那人独居不好，我要为他造一个配偶帮助他。",
    "type": "genesis",
    "from": "创世记 2:18",
    "creator": "bible",
    "created_at": "0",
    "length": 22
  },
  {
    "id": 8,
    "uuid": "genesis-8",
    "bibleverses": "人要离开父母，与妻子连合，二人成为一体。",
    "type": "genesis",
    "from": "创世记 2:24",
    "creator": "bible",
    "created_at": "0",
    "length": 22
  },
  {
    "id": 9,
    "uuid": "genesis-9",
    "bibleverses": "惟有挪亚在耶和华眼前蒙恩。",
    "type": "genesis",
    "from": "创世记 6:8",
    "creator": "bible",
    "created_at": "0",
    "length": 16
  },
  {
    "id": 10,
    "uuid": "genesis-10",
    "bibleverses": "地还存留的时候，稼穑、寒暑、冬夏、昼夜就永不停息了。",
    "type": "genesis",
    "from": "创世记 8:22",
    "creator": "bible",
    "created_at": "0",
    "length": 28
  },

  {
    "id": 50,
    "uuid": "exodus-50",
    "bibleverses": "因为我耶和华是医治你的。",
    "type": "exodus",
    "from": "出埃及记 15:26",
    "creator": "bible",
    "created_at": "0",
    "length": 10
  },
  {
    "id": 51,
    "uuid": "exodus-51",
    "bibleverses": "容我的百姓去，好事奉我。",
    "type": "exodus",
    "from": "出埃及记 8:1",
    "creator": "bible",
    "created_at": "0",
    "length": 14
  },
  {
    "id": 52,
    "uuid": "exodus-52",
    "bibleverses": "耶和华吩咐摩西说：“你进去见法老，对他说：容我的百姓去，好事奉我。”",
    "type": "exodus",
    "from": "出埃及记 8:1",
    "creator": "bible",
    "created_at": "0",
    "length": 24
  },
  {
    "id": 53,
    "uuid": "exodus-53",
    "bibleverses": "耶和华对摩西说：“你向天伸手，使埃及地黑暗；这黑暗似乎摸得着。”",
    "type": "exodus",
    "from": "出埃及记 10:21",
    "creator": "bible",
    "created_at": "0",
    "length": 24
  },
  {
    "id": 80,
    "uuid": "exodus-80",
    "bibleverses": "众百姓说：“耶和华所吩咐的，我们都必遵守行。”",
    "type": "exodus",
    "from": "出埃及记 24:7",
    "creator": "bible",
    "created_at": "0",
    "length": 18
  },
  {
    "id": 81,
    "uuid": "exodus-81",
    "bibleverses": "我要恩待谁就恩待谁，要怜悯谁就怜悯谁。",
    "type": "exodus",
    "from": "出埃及记 33:19",
    "creator": "bible",
    "created_at": "0",
    "length": 22
  },
  {
    "id": 82,
    "uuid": "exodus-82",
    "bibleverses": "耶和华，耶和华，是有怜悯有恩典的神，不轻易发怒，并有丰盛的慈爱和诚实。",
    "type": "exodus",
    "from": "出埃及记 34:6-7",
    "creator": "bible",
    "created_at": "0",
    "length": 56
  }
]
